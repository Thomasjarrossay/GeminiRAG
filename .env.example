# ============================================================
# GeminiRAG — Template de variables d'environnement
# ============================================================
# Copiez ce fichier : cp .env.example .env
# Puis remplissez chaque valeur avec vos clés réelles.
# ============================================================

# Google AI Studio → https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_ai_studio_key_here

# Qdrant Cloud → https://cloud.qdrant.io  |  ou http://localhost:6333 en local
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=geminirag

# Dimensions des vecteurs Gemini (768 recommandé)
EMBEDDING_DIM=768

# OpenRouter → https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=anthropic/claude-opus-4-6

# Serveur
HOST=0.0.0.0
PORT=8000
